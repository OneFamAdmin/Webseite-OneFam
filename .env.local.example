# OneFam — environment variables.
# Copy this file to ".env.local" and fill in the values. NEVER commit .env.local.

# Supabase  (Project Settings → API). Choose the EU/Frankfurt region for DSG.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret — admin writes (pool amount, draws). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Draw randomness (drand). Public League-of-Entropy mainnet by default.
DRAND_CHAIN_URL=https://api.drand.sh

# E-mail address that gets /admin access (must match a logged-in user).
ADMIN_EMAIL=

# E-mail sending (Resend — https://resend.com). Create a free account + API key.
RESEND_API_KEY=
# Sender. Until you verify onefam.ch in Resend, the test sender below only
# delivers to your OWN Resend account e-mail. After verifying the domain use e.g.:
#   EMAIL_FROM=OneFam <info@onefam.ch>
EMAIL_FROM=OneFam <onboarding@resend.dev>
# Public site URL used in e-mail links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shopify webhooks — automatic buyer recognition (no Admin-API token needed).
# In Shopify: Settings → Notifications → Webhooks → create three JSON webhooks
# (Order payment, Refund creation, Order cancellation) pointing at
#   https://webseite-one-fam.vercel.app/api/shopify/webhook
# then copy the signing secret shown under the Webhooks section here.
SHOPIFY_WEBHOOK_SECRET=
